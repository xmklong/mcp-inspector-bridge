{
	"name": "mcp-inspector-bridge",
	"version": "0.0.9",
	"description": "Modern Cocos Inspector Bridge using TypeScript and Vue 3",
	"author": "Firekula",
	"main": "dist/main.js",
	"scripts": {
		"build": "tsc && esbuild src/probe/index.ts --bundle --outfile=dist/probe.js && esbuild src/mcp-client/index.ts --bundle --platform=node --outfile=dist/mcp-client/index.js",
		"watch": "tsc -w & esbuild src/probe/index.ts --bundle --outfile=dist/probe.js --watch & esbuild src/mcp-client/index.ts --bundle --platform=node --outfile=dist/mcp-client/index.js --watch"
	},
	"main-menu": {
		"MCP 桥接器/开启运行时面板": {
			"message": "mcp-inspector-bridge:open"
		}
	},
	"scene-script": "dist/scene-script.js",
	"panel": {
		"main": "dist/panel/index.js",
		"type": "dockable",
		"title": "⚔︎ 预览面板",
		"width": 800,
		"height": 600
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"@types/ws": "^8.18.1",
		"esbuild": "^0.27.4",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"vue": "^3.5.31",
		"ws": "^8.20.0"
	}
}
